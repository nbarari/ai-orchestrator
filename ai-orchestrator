# .ai-orchestrator

Project-level configuration for the AI Orchestrator framework.
This file is read by IDE rules, agents, and CI checks to determine
which gate criteria are active for this project.

[project]
name = ai-orchestrator-framework
version = 0.1
current_phase = 1

# Build-Time, Runtime, or Both
ai_deployment_mode = Both

[gate_0]
